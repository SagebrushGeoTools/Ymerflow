#!/bin/bash
# Debug harness for running Nagelfluh processes with pdb

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CONFIG_FILE="${CONFIG_FILE:-$SCRIPT_DIR/config.json}"

# Configure Docker to use minikube's daemon (where the image is)
echo "Configuring Docker to use minikube's daemon..."
eval $(minikube docker-env)
echo ""

# Load environment variables from .env if it exists
if [ -f "$PROJECT_ROOT/.env" ]; then
    echo "Loading environment from $PROJECT_ROOT/.env"
    set -a  # automatically export all variables
    source "$PROJECT_ROOT/.env"
    set +a
    echo ""
fi

# Check if config file exists
if [ ! -f "$CONFIG_FILE" ]; then
    echo "Error: Configuration file not found: $CONFIG_FILE"
    echo ""
    echo "Please create config.json from the template:"
    echo "  cp config.json.template config.json"
    echo "  # Edit config.json with your values"
    echo ""
    echo "Or set CONFIG_FILE environment variable to point to your config file."
    exit 1
fi

# Parse config file using Python
read -r PROCESS_TYPE PROCESS_ID VERSION PROJECT_ID DOCKER_IMAGE STORAGE_BASE CONFIG_STORAGE_ENDPOINT CONFIG_AWS_ACCESS_KEY CONFIG_AWS_SECRET_KEY PARAMETERS_JSON < <(python3 <<EOF
import json
import sys

with open('$CONFIG_FILE') as f:
    config = json.load(f)

# Print space-separated values
print(
    config['process_type'],
    config['process_id'],
    config['version'],
    config['project_id'],
    config['docker_image'],
    config['storage_base'],
    config['storage_endpoint'],
    config['aws_access_key_id'],
    config['aws_secret_access_key'],
    json.dumps(config['parameters'])
)
EOF
)

# Override with .env values if available (and config has placeholder values)
# Storage endpoint - convert localhost to internal service name like K8s does
if [ -n "$STORAGE_ENDPOINT" ]; then
    FINAL_STORAGE_ENDPOINT="$STORAGE_ENDPOINT"
else
    FINAL_STORAGE_ENDPOINT="$CONFIG_STORAGE_ENDPOINT"
fi

# Convert localhost endpoint to internal K8s service name for pod access
# This mimics what job_orchestrator.py does for K8s pods
FINAL_STORAGE_ENDPOINT="${FINAL_STORAGE_ENDPOINT/http:\/\/localhost:9000/http:\/\/minio-nagelfluh.nagelfluh-jobs.svc.cluster.local:9000}"

# AWS credentials - try multiple sources in order:
# 1. AWS_ACCESS_KEY_ID from .env
# 2. MINIO_ROOT_USER from .env (for local dev)
# 3. Config file value (if not placeholder)
if [ -n "$AWS_ACCESS_KEY_ID" ]; then
    FINAL_AWS_ACCESS_KEY="$AWS_ACCESS_KEY_ID"
    FINAL_AWS_SECRET_KEY="${AWS_SECRET_ACCESS_KEY:-$CONFIG_AWS_SECRET_KEY}"
    CRED_SOURCE="AWS_ACCESS_KEY_ID from .env"
elif [ -n "$MINIO_ROOT_USER" ]; then
    FINAL_AWS_ACCESS_KEY="$MINIO_ROOT_USER"
    FINAL_AWS_SECRET_KEY="$MINIO_ROOT_PASSWORD"
    CRED_SOURCE="MINIO_ROOT_USER from .env"
elif [ "$CONFIG_AWS_ACCESS_KEY" != "YOUR_ACCESS_KEY" ]; then
    FINAL_AWS_ACCESS_KEY="$CONFIG_AWS_ACCESS_KEY"
    FINAL_AWS_SECRET_KEY="$CONFIG_AWS_SECRET_KEY"
    CRED_SOURCE="config.json"
else
    echo "Error: No AWS/MinIO credentials found!"
    echo ""
    echo "Please either:"
    echo "  1. Add AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY to $PROJECT_ROOT/.env"
    echo "  2. Or ensure MINIO_ROOT_USER/MINIO_ROOT_PASSWORD are in .env"
    echo "  3. Or edit aws_access_key_id/aws_secret_access_key in config.json"
    exit 1
fi

echo "=========================================="
echo "Starting Debug Container"
echo "=========================================="
echo "Process Type: $PROCESS_TYPE"
echo "Process ID: $PROCESS_ID"
echo "Version: $VERSION"
echo "Project ID: $PROJECT_ID"
echo "Docker Image: $DOCKER_IMAGE"
echo "Storage Base: $STORAGE_BASE"
echo "Storage Endpoint: $FINAL_STORAGE_ENDPOINT"
echo "Credentials Source: $CRED_SOURCE"
echo "AWS Access Key: ${FINAL_AWS_ACCESS_KEY:0:8}..."
echo "=========================================="
echo ""

# Run Docker container with debug runner mounted
# This mounts:
# - debug_runner.py as the entrypoint
# - Current directory for access to data files if needed
# - Uses existing Docker image without modification

docker run -it --rm \
    --pull=never \
    -v "$SCRIPT_DIR/debug_runner.py:/app/debug_runner.py:ro" \
    -v "$SCRIPT_DIR:/debug:ro" \
    -e PROCESS_TYPE="$PROCESS_TYPE" \
    -e PROCESS_ID="$PROCESS_ID" \
    -e VERSION="$VERSION" \
    -e PROJECT_ID="$PROJECT_ID" \
    -e PARAMETERS_JSON="$PARAMETERS_JSON" \
    -e BACKEND_URL="http://localhost:8000" \
    -e STORAGE_BASE="$STORAGE_BASE" \
    -e STORAGE_ENDPOINT="$FINAL_STORAGE_ENDPOINT" \
    -e AWS_ACCESS_KEY_ID="$FINAL_AWS_ACCESS_KEY" \
    -e AWS_SECRET_ACCESS_KEY="$FINAL_AWS_SECRET_KEY" \
    "$DOCKER_IMAGE" \
    python /app/debug_runner.py

echo ""
echo "=========================================="
echo "Debug session ended"
echo "=========================================="
