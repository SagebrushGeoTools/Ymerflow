# Nagelfluh configuration
# Copy this file to config.env and edit it for your environment.
# config.env is gitignored and never committed.

# Deployment mode:
#   development         = backend and frontend run on the host machine
#   production-minikube = all services run inside Minikube as Kubernetes pods
DEPLOYMENT=development

# Minikube resources (used in both dev and prod)
MINIKUBE_CPUS=4
MINIKUBE_MEMORY=8192

# ── Production-only settings (only used when DEPLOYMENT=production-minikube) ──

# Public URL of the API as seen by client browsers.
# The frontend embeds this URL into dataset links, so it must be reachable
# from the end-user's browser — not just from the server itself.
# Examples:
#   Plain IP:  BACKEND_BASE_URL=http://192.168.1.100:3000/api
#   Domain:    BACKEND_BASE_URL=https://nagelfluh.example.com/api
# BACKEND_BASE_URL=https://nagelfluh.example.com/api

# IP address or hostname clients use to reach this server.
# Defaults to the primary non-loopback IP of the host.
# HOST_IP=192.168.1.100

# Port to expose the app on (default: 3000). Use 80 for standard HTTP.
# FRONTEND_PORT=80
