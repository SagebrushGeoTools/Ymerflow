# External images used in the Nagelfluh development environment.
# Pin specific release tags so cold minikube starts (after `minikube delete`)
# don't fail waiting for registry pulls. Update these when upgrading components.
#
# k8s/ production manifests reference these images directly with matching tags;
# keep them in sync when bumping versions here.

MINIO_IMAGE="minio/minio:RELEASE.2025-10-15T17-29-55Z"
REGISTRY_IMAGE="registry:2.8.3"
