#!/usr/bin/env python
"""Print a registry protocol's pod image-pull credential as JSON.

Usage: nagelfluh-registry-pull-credentials <protocol> <config-json>

Resolves via RegistryProtocolHandler.pull_credentials(config) — the SAME mechanism
job_orchestrator.py uses for process-runner pods and nagelfluh-deploy-app uses for the app's own
Deployments — so a caller (e.g. prod/runall-production.sh's Step 6c app image-pull Secret) never
has to assume docker-v2's basic-auth shape (--docker-username/--docker-password) directly.

Prints {"username": ..., "password": ...} to stdout (values may be null, e.g. for a protocol whose
registry needs no pull credential at all); all diagnostics go to stderr.
"""
import asyncio
import json
import os
import sys

# Ensure the project root is on sys.path so backend modules are importable.
_project_root = os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
if _project_root not in sys.path:
    sys.path.insert(0, _project_root)

from backend.services.registry_protocols import get_registry_protocol_handler


def main():
    if len(sys.argv) != 3:
        print(f"Usage: {sys.argv[0]} <protocol> <config-json>", file=sys.stderr)
        sys.exit(1)

    protocol, config_json = sys.argv[1], sys.argv[2]
    config = json.loads(config_json)

    handler = get_registry_protocol_handler(protocol)
    creds = asyncio.run(handler.pull_credentials(config))

    print(json.dumps({
        "username": creds.get("username"),
        "password": creds.get("password"),
    }))


if __name__ == "__main__":
    main()
