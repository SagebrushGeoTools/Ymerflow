#!/usr/bin/env python
"""Resolve the active cluster's provider and print a kubeconfig for it.

Every kubectl-based script in the host repo (prod/runall-production.sh, docker/build.sh,
backup.sh, restore.sh, debug-harness/run_debug.sh) uses this as the ONE channel to reach a
cluster — see docs/plans/base-infrastructure-via-cluster-provider.md, Design decision 1. It must
never invoke `kubectl` against whatever context happens to be ambient; this script resolves the
correct one explicitly via ClusterProvider.materialize_kubeconfig().

Resolves CLUSTER_TYPE/CLUSTER_CONFIG_JSON from this process's own environment — the SAME env vars
(with the same "same-as-backend" default) nagelfluh-bootstrap-provision/nagelfluh-deploy-app
already resolve the cluster from; see those scripts' docstrings for why this is env-driven rather
than DB-driven (the DB row these env vars ultimately seed does not exist yet on a fresh deploy).

Usage:
    nagelfluh-materialize-kubeconfig            # kubeconfig YAML to stdout
    nagelfluh-materialize-kubeconfig --export   # `export KUBECONFIG=<tmpfile>` to stdout, for
                                                 # eval'ing directly into the caller's shell

Only the kubeconfig (or the `export` line) goes to stdout — all diagnostics go to stderr.
"""
import argparse
import json
import os
import sys
import tempfile

import yaml

# Ensure the project root is on sys.path so backend modules are importable.
_project_root = os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
if _project_root not in sys.path:
    sys.path.insert(0, _project_root)

from backend.services.cluster_providers import get_cluster_provider


def main():
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--export", action="store_true",
        help="Write the kubeconfig to a temp file and print `export KUBECONFIG=<path>` instead "
             "of the kubeconfig YAML itself.",
    )
    args = parser.parse_args()

    cluster_type = os.getenv("CLUSTER_TYPE") or "same-as-backend"
    cluster_config_json = os.getenv("CLUSTER_CONFIG_JSON")
    cluster_config = json.loads(cluster_config_json) if cluster_config_json else {}

    print(f"Materializing kubeconfig for cluster_type={cluster_type!r}...", file=sys.stderr)
    provider = get_cluster_provider(cluster_type)
    kubeconfig = provider.materialize_kubeconfig(cluster_config)
    kubeconfig_yaml = yaml.safe_dump(kubeconfig, default_flow_style=False)

    if args.export:
        fd, path = tempfile.mkstemp(prefix="nagelfluh-kubeconfig-", suffix=".yaml")
        with os.fdopen(fd, "w") as f:
            f.write(kubeconfig_yaml)
        print(f"export KUBECONFIG={path}")
    else:
        print(kubeconfig_yaml)


if __name__ == "__main__":
    main()
