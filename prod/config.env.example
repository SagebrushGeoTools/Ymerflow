# Site-specific configuration for prod/runall-minikube.sh
# Copy this file to prod/config.env and edit it for your server.
# prod/config.env is gitignored and never committed.

# Public URL of the API as seen by client browsers.
# Required when running behind a reverse proxy or with a real hostname/SSL.
# Example: BACKEND_BASE_URL=https://nagelfluh.example.com/api
BACKEND_BASE_URL=https://ymerflow.earth/api

# Optional: override the host IP or port used for the socat forwarder.
# HOST_IP=192.168.1.100
# FRONTEND_PORT=80
