# Database Configuration
# Use sqlite:/// for local SQLite database
# Use postgresql:// for PostgreSQL (e.g., postgresql://user:password@localhost/dbname)
DATABASE_URL=sqlite:///./nagelfluh.db

# File Storage Configuration (Legacy)
# Local file storage: file://./data_storage
DATA_BASE_PATH=file://./data_storage

# Per-Project Bucket Storage
# Protocol: s3 (MinIO/AWS), gcs (Google Cloud), az (Azure), file (local)
STORAGE_PROTOCOL=s3
# Endpoint: MinIO URL for dev (http://localhost:9000 via port-forward) or empty for cloud
# Note: Use localhost:9000 for backend; pods get internal service name auto-injected
STORAGE_ENDPOINT=http://localhost:9000
# Bucket prefix: project buckets named {prefix}{project_id}
STORAGE_BUCKET_PREFIX=nagelfluh-project-

# MinIO Admin Credentials (for bucket/user management via Python SDK)
# These are used by the backend to create buckets, users, and policies
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Authentication Configuration
# Generate a secure random key for production:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=30

# Application Configuration
# Cost per process execution (credits)
PROCESS_COST=0.10

# Initial balance for new users (credits)
INITIAL_USER_BALANCE=100.0

# CORS Configuration
# Comma-separated list of allowed origins
# For development: http://localhost:3000
# For production: https://your-domain.com
#CORS_ORIGINS=http://localhost:3000

# Backend API Base URL
# For development: http://localhost:8000
# For production: https://api.your-domain.com
BACKEND_BASE_URL=http://localhost:8000

# Container Registry Configuration
# For development: registry:5000 (after running dev/setup-registry.sh)
# For production: us-central1-docker.pkg.dev/your-project/nagelfluh-environments
REGISTRY_URL=registry:5000
# Registry authentication (base64 encoded username:password, or empty for no auth)
# For development: leave empty (no auth required)
# For production: use service account credentials
REGISTRY_AUTH=
