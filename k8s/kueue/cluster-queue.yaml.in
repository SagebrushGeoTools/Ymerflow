apiVersion: kueue.x-k8s.io/v1beta2
kind: ResourceFlavor
metadata:
  name: default-flavor
---
apiVersion: kueue.x-k8s.io/v1beta2
kind: ClusterQueue
metadata:
  name: nagelfluh-cluster-queue
spec:
  namespaceSelector: {}
  resourceGroups:
  - coveredResources: ["cpu", "memory", "ephemeral-storage"]
    flavors:
    - name: default-flavor
      resources:
      - name: "cpu"
        nominalQuota: ${KUEUE_CPU_QUOTA}
      - name: "memory"
        nominalQuota: ${KUEUE_MEMORY_QUOTA}
      - name: "ephemeral-storage"
        nominalQuota: 100Gi
---
apiVersion: kueue.x-k8s.io/v1beta2
kind: LocalQueue
metadata:
  name: nagelfluh-queue
  namespace: nagelfluh-jobs
spec:
  clusterQueue: nagelfluh-cluster-queue
